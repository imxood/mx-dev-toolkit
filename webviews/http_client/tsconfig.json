{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2022"
    ],
    "types": [
      "vite/client",
      "node"
    ],
    "strict": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./vite-env.d.ts"
  ]
}
