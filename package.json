{
  "name": "mx-dev-toolkit",
  "displayName": "Mx Dev Toolkit",
  "description": "Mx personal developer toolkit for daily VSCode workflows",
  "version": "0.2.3",
  "publisher": "maxu",
  "repository": "https://github.com/imxood/mx-dev-toolkit",
  "engines": {
    "vscode": "^1.79.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": [
      {
        "title": "Mx Dev Toolkit",
        "properties": {
          "mx-dev-toolkit.Uv4Path": {
            "type": "string",
            "scope": "machine",
            "markdownDescription": "MDK UV4.exe path",
            "default": "C:/Keil_v5/UV4/UV4.exe"
          }
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mx-dev-toolkit-httpClientContainer",
          "title": "HTTP Client",
          "icon": "media/http-lab.svg"
        }
      ]
    },
    "views": {
      "mx-dev-toolkit-httpClientContainer": [
        {
          "type": "webview",
          "id": "mx-dev-toolkit-httpClientLauncher",
          "name": "HTTP Client"
        }
      ]
    },
    "commands": [
      {
        "command": "mx-dev-toolkit.httpClient.openWorkbench",
        "title": "mx http open"
      },
      {
        "command": "mx-dev-toolkit.httpClient.sendCurrent",
        "title": "mx http send"
      },
      {
        "command": "mx-dev-toolkit.httpClient.saveCurrent",
        "title": "mx http save"
      },
      {
        "command": "mx-dev-toolkit.httpClient.importCurl",
        "title": "mx http import curl"
      },
      {
        "command": "mx-dev-toolkit.httpClient.runLoadTest",
        "title": "mx http load test"
      },
      {
        "command": "mx-dev-toolkit.keil.build",
        "title": "mx keil build"
      },
      {
        "command": "mx-dev-toolkit.keil.rebuild",
        "title": "mx keil rebuild"
      },
      {
        "command": "mx-dev-toolkit.keil.clean",
        "title": "mx keil clean"
      },
      {
        "command": "mx-dev-toolkit.keil.generateConfig",
        "title": "mx keil gen config"
      }
    ],
    "keybindings": [
      {
        "command": "mx-dev-toolkit.selection.copyRelativeRange",
        "key": "ctrl+alt+c",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "mx-dev-toolkit.selection.copyAbsoluteRange",
        "key": "ctrl+shift+alt+c",
        "when": "editorTextFocus && !editorReadonly"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "pnpm run compile:webview && pnpm run compile:extension",
    "compile:extension": "tsc -p ./ --noEmit && esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --outfile=out/extension.js --external:vscode --sourcemap",
    "compile:webview": "tsc -p ./webviews/http_client/tsconfig.json --noEmit && vite build --config webviews/http_client/vite.config.ts",
    "watch": "concurrently -k --names webview,extension --prefix-colors blue,green \"pnpm watch:webview\" \"pnpm watch:extension\"",
    "watch:extension": "esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --outfile=out/extension.js --external:vscode --sourcemap --watch",
    "watch:webview": "vite build --watch --config webviews/http_client/vite.config.ts",
    "lint": "eslint src webviews/http_client --ext ts,tsx",
    "test:http-client:core": "tsc -p ./tsconfig.test.json && node --test --test-concurrency=1 out-tests/http_client/tests/store.test.js out-tests/http_client/tests/resolver.test.js out-tests/http_client/tests/runner.test.js out-tests/http_client/tests/load_runner.test.js out-tests/http_client/tests/curl_import.test.js out-tests/http_client/tests/webview_state.test.js out-tests/http_client/tests/sidebar_view.test.js out-tests/http_client/tests/react_loader.test.js out-tests/http_client/tests/panel.test.js",
    "test:http-client:webview": "tsc -p ./tsconfig.webview_test.json && node --test --test-concurrency=1 out-tests-webview/webviews/http_client/tests/workbench_model.test.js out-tests-webview/webviews/http_client/tests/sidebar_model.test.js",
    "test:http-client": "pnpm test:http-client:core && pnpm test:http-client:webview",
    "test:toast": "tsc -p ./tsconfig.test.json && node --test --test-concurrency=1 out-tests/toast/tests/service.test.js",
    "test": "pnpm test:http-client && pnpm test:toast"
  },
  "packageManager": "pnpm@10.11.0",
  "devDependencies": {
    "@tailwindcss/vite": "4.2.2",
    "@types/mocha": "^10.0.6",
    "@types/node": "~25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/vscode": "^1.79.0",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.3.9",
    "concurrently": "9.2.1",
    "dayjs": "^1.11.11",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.2",
    "json5": "^2.2.3",
    "tailwindcss": "4.2.2",
    "typescript": "^5.4.5",
    "vite": "8.0.8",
    "xml2js": "^0.6.2"
  },
  "dependencies": {
    "react": "19.2.5",
    "react-dom": "19.2.5"
  }
}
